# Enable MPU
CONFIG_ARM_MPU=y

# Enable HW stack protection
CONFIG_HW_STACK_PROTECTION=y

# Enable serial
CONFIG_SERIAL=y

# Enable console
CONFIG_CONSOLE=y
CONFIG_UART_CONSOLE=y

# Enable GPIO
CONFIG_GPIO=y

# TODO: Remove this - but for now, it is needed to ensure proper 
# alignment of LVGL buffers when using the Nema GFX library.
CONFIG_LV_ATTRIBUTE_MEM_ALIGN_SIZE=4
